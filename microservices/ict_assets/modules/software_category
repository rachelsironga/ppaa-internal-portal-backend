# software_category.py
from datetime import datetime
from django.db import transaction
from django.db.models import Q
from rest_framework.exceptions import NotFound
from rest_framework.permissions import IsAuthenticated
from rest_framework.views import APIView

from ict_assets.models import SoftwareCategory
from ict_assets.serializers import SoftwareCategorySerializer
from mnh_approval.pagination import CustomPagination
from mnh_approval.response_codes import CustomResponse, STATUS_CODES
from utils.permissions import HasMethodPermission


class SoftwareCategoryView(APIView):
    permission_classes = [IsAuthenticated, HasMethodPermission]
    serializer_class = SoftwareCategorySerializer
    required_permissions = {
        "get": [
            "view_softwarecategory"
        ],
        "post": [
            "add_softwarecategory",
            "change_softwarecategory",
        ],
        "delete": [
            "delete_softwarecategory",
        ]
    }

    def get(self, request, uid=None):
        try:
            if uid:
                software_category = SoftwareCategory.objects.filter(uid=uid, is_deleted=False).first()
                if not software_category:
                    raise NotFound("Software Category not found")
                return CustomResponse.success(data=SoftwareCategorySerializer(software_category).data)

            search_query = request.GET.get('search', '').strip()
            software_categories = SoftwareCategory.objects.filter(is_deleted=False)

            if search_query:
                software_categories = software_categories.filter(
                    Q(name__icontains=search_query) | 
                    Q(description__icontains=search_query)
                )

            if software_categories.exists():
                return CustomPagination.paginate(view_class=self, results=software_categories, request=request)

            return CustomResponse.errors(message="Software Categories not found", data=[])
        except Exception as e:
            return CustomResponse.server_error(message=f'Failed to Retrieve Software Categories: {str(e)}')

    def post(self, request):
        try:
            with transaction.atomic():
                uid = request.data.get('uid', None)
                if uid:
                    try:
                        instance = SoftwareCategory.objects.get(uid=uid, is_deleted=False)
                        serializer = self.serializer_class(instance, data=request.data, partial=True, context={'request': request})
                    except SoftwareCategory.DoesNotExist:
                        return CustomResponse.errors(message="Software Category not found")
                else:
                    serializer = self.serializer_class(data=request.data, context={'request': request})

                if serializer.is_valid():
                    serializer.save()
                    return CustomResponse.success(data=serializer.data)

                return CustomResponse.errors(
                    message="Validation Failed, Please Try Again",
                    data=serializer.errors,
                    code=STATUS_CODES["VALIDATION_ERROR"],
                )

        except Exception as e:
            return CustomResponse.server_error(message=f'Failed to Change Software Category: {str(e)}')

    def delete(self, request, uid):
        try:
            with transaction.atomic():
                software_category = SoftwareCategory.objects.filter(uid=uid, is_deleted=False).first()
                if not software_category:
                    return CustomResponse.errors(message="Software Category Not Found or Already Deleted")

                software_category.is_deleted = True
                software_category.deleted_at = datetime.now()
                software_category.deleted_by = request.user
                software_category.save()
                return CustomResponse.success(message='Software Category deleted successfully')

        except Exception as e:
            return CustomResponse.server_error(message="Something went wrong While Deleting Software Category")
        



        