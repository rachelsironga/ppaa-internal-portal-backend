# --- Production .env template ---
# Copy this file to .env (exact name) — docker-compose.yml uses env_file: .env only.
# If you maintain a file named `env`, run: cp env .env  (or symlink) before docker compose up.
# Set real secrets before deployment.

# Network defaults (used by CORS/CSRF helper + frontend/email link generation)
LAN_HOST=192.168.1.4
LAN_SUBNET_CIDR=192.168.1.0/24
FRONTEND_URL=http://192.168.1.4:3000
AUTH_SERVICE_URL=http://192.168.1.4:8000
# Base URL the browser must use for anonymous public assets (quick-link logos, popup/PR images).
# Must match nginx → Django (LAN default http://LAN_HOST:8092). Wrong scheme/port breaks <img src>.
PUBLIC_API_ORIGIN=http://192.168.1.4:8092

# CORS / CSRF notes:
# settings_prod merges LAN_HOST ports (8091, 8092, 3000, 4001, 4002, 8000) plus FRONTEND_URL,
# PORTAL_PUBLIC_URL, and AUTH_SERVICE_URL when set. Match the URL users type in the browser (scheme + host + port).
# If you deploy behind HTTPS/reverse proxy, update settings_prod.py trusted origins accordingly.

# Django — DEBUG read from env in settings_prod. For plain HTTP on LAN, leave FORCE_HTTPS unset/false
# (setting SSL redirect without real HTTPS breaks login and shows "Provisional headers" / failed requests in Chrome).
# FORCE_HTTPS=true

# Django
DEBUG=False
DJANGO_SETTINGS_MODULE=ppaa_portal.settings_prod
DJANGO_SECRET_KEY=CHANGE_ME__GENERATE_A_LONG_RANDOM_SECRET_KEY
# Optional: max request body Django will buffer in memory (MiB). Default in settings_prod is 55 (document JSON+base64).
# DATA_UPLOAD_MAX_MB=55

# Main PostgreSQL connection
POSTGRES_DB_NAME=ppaa_internal_portal
POSTGRES_DB_USER=postgres
POSTGRES_DB_PWD=P@ssw0rd
POSTGRES_DB_HOST=postgres
POSTGRES_DB_PORT=5432

# Secondary logical DBs (same PostgreSQL server; explicit for production clarity)
PERFORMANCE_DASHBOARD_DB_NAME=performance_dashboard_db
PERFORMANCE_DASHBOARD_DB_USER=postgres
PERFORMANCE_DASHBOARD_DB_PWD=P@ssw0rd
PERFORMANCE_DASHBOARD_DB_HOST=postgres
PERFORMANCE_DASHBOARD_DB_PORT=5432

MAONI_DB_NAME=maoni_db
MAONI_DB_USER=postgres
MAONI_DB_PWD=P@ssw0rd
MAONI_DB_HOST=postgres
MAONI_DB_PORT=5432

# settings_prod.py uses REPORTS_MANAGEMENT_DB_* keys
REPORTS_MANAGEMENT_DB_NAME=reports_management_db
REPORTS_MANAGEMENT_DB_USER=postgres
REPORTS_MANAGEMENT_DB_PWD=P@ssw0rd
REPORTS_MANAGEMENT_DB_HOST=postgres
REPORTS_MANAGEMENT_DB_PORT=5432

# Email settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true
EMAIL_HOST_USER=rachelsironga2@gmail.com
EMAIL_HOST_PASSWORD=dtpmezvnaukmndvz
DEFAULT_FROM_EMAIL=info@ppaa.go.tz


# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
# Optional toggles:
# CELERY_TASK_ALWAYS_EAGER=1
# RMS_REMINDERS_BEAT=0

# Optional reminder links
PORTAL_PUBLIC_URL=http://192.168.1.4:3000


# MinIO / S3
# Use a reachable MinIO endpoint from the backend container/host.
# - Docker Compose backend -> usually http://minio:9000
# - External/LAN MinIO -> e.g. http://192.168.1.4:9000
AWS_S3_ENDPOINT_URL=http://minio:9000
# MUST match docker-compose.yml `minio` service exactly (or you get SignatureDoesNotMatch and backend restart loop):
#   AWS_ACCESS_KEY_ID  == MINIO_ROOT_USER
#   AWS_SECRET_ACCESS_KEY == MINIO_ROOT_PASSWORD
AWS_ACCESS_KEY_ID=rachel.sironga
AWS_SECRET_ACCESS_KEY=P@ssw0rd
# Django default storage bucket (single required bucket; no spaces in bucket names)
AWS_STORAGE_BUCKET_NAME=internal-portal
# When the above MinIO/S3 vars are set, internal portal file uploads (documents, quick-link logos,
# announcements, popup/PR images) are written with MinioStorage.put_object to this bucket; otherwise
# they fall back to default_storage (e.g. local dev without MinIO).
# Optional additional app bucket names (if your code uses them)
SPM_BUCKET_NAME=strategic-performance-management
RMS_REPORTS_BUCKET=reports-management
AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_ADDRESSING_STYLE=path
# Run once after first deploy OR after MinIO data reset/new volume:
# docker compose exec backend python manage.py ensure_s3_media_bucket

# Docker build fallback image note:
# If mirror.gcr.io fails DNS, use public.ecr.aws/docker/library/python:3.12-slim
DOCKER_PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
