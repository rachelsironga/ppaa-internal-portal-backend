# Celery / Redis (defaults in settings.py use 127.0.0.1 for local runserver)
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# No Redis: run tasks in-process (emails send from the web process)
# CELERY_TASK_ALWAYS_EAGER=1
